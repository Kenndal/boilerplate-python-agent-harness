# Copy to `.env` for local Docker Compose: `cp .env.example .env`
# `.env` is gitignored — adjust secrets for your environment.

# PostgreSQL (db service — official image variables)
POSTGRES_DB=app_db
POSTGRES_USER=db_master_admin
POSTGRES_PASSWORD=db_master_admin_password

# FastAPI application (matches src/config/config.py)
DATABASE_HOSTNAME=db
DATABASE_USERNAME=db_master_admin
DATABASE_PASSWORD=db_master_admin_password
DATABASE_NAME=app_db
DATABASE_PORT=5432
DATABASE_SCHEMA=sample_schema

IS_PROD=false
LOG_FILE_PATH=/var/log/app/app.log
LOG_LEVEL=INFO

# LLM / Agent (OpenRouter via OpenAI-compatible API)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_DEFAULT_MODEL=openai/gpt-4o-mini
LLM_REQUEST_TIMEOUT_S=60
LLM_HTTP_REFERER=
LLM_APP_TITLE=
